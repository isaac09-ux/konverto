---
interface Props {
  heading: string;
  lead: string;
  includeTitle: string;
  includeItems: string[];
  focusTitle: string;
  focusText: string;
  ctaTitle: string;
  ctaText: string;
  ctaHref: string;
  ctaLabel: string;
  relatedHref: string;
  relatedLabel: string;
  schema: Record<string, unknown>;
}

const props = Astro.props;
---

<main class="container">
  <a class="back-link" href="/">← Volver a KONVERTO</a>

  <header class="hero">
    <p class="badge">Servicio especializado</p>
    <h1>{props.heading}</h1>
    <p class="lead">{props.lead}</p>
  </header>

  <section class="grid">
    <article class="card">
      <h2>{props.includeTitle}</h2>
      <ul>
        {props.includeItems.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class="card">
      <h2>{props.focusTitle}</h2>
      <p>{props.focusText}</p>
      <p class="related">También te puede interesar <a href={props.relatedHref}>{props.relatedLabel}</a>.</p>
    </article>
  </section>

  <section class="cta">
    <h2>{props.ctaTitle}</h2>
    <p>{props.ctaText}</p>
    <a class="cta-button" href={props.ctaHref} target="_blank" rel="noopener noreferrer">{props.ctaLabel}</a>
  </section>
</main>

<script type="application/ld+json" is:inline>{JSON.stringify(props.schema)}</script>

<style>
  .hero {
    margin-top: 18px;
    padding: 28px;
    border: 1px solid rgba(191,255,0,.2);
    background: linear-gradient(160deg, rgba(191,255,0,.08), rgba(16,17,20,.9));
    border-radius: 18px;
  }

  .badge {
    margin: 0;
    font-size: .8rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--lime);
    font-weight: 700;
  }

  h1, h2 {
    font-family: 'Outfit', sans-serif;
    margin: 10px 0;
    line-height: 1.15;
  }

  h1 { font-size: clamp(2rem, 4.2vw, 3.2rem); }
  h2 { font-size: clamp(1.25rem, 2.2vw, 1.8rem); }

  .lead {
    margin-top: 10px;
    color: #d9d9d3;
    max-width: 70ch;
    font-size: 1.05rem;
  }

  .grid {
    margin-top: 24px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .card {
    border-radius: 16px;
    border: 1px solid rgba(191,255,0,.15);
    background: var(--dark2);
    padding: 22px;
  }

  ul { padding-left: 20px; margin: 0; }
  li { margin-bottom: 10px; }
  p { color: #deded8; }

  .cta {
    margin-top: 24px;
    padding: 26px;
    border-radius: 16px;
    background: var(--dark3);
    border: 1px solid rgba(191,255,0,.16);
  }

  .cta-button {
    display: inline-block;
    margin-top: 10px;
    background: var(--lime);
    color: #111;
    text-decoration: none;
    padding: 12px 16px;
    border-radius: 10px;
    font-weight: 700;
  }

  .related { color: #b8b8b1; }
  .related a { color: var(--lime); }

  @media (max-width: 820px) {
    .grid { grid-template-columns: 1fr; }
    .hero, .card, .cta { padding: 18px; }
  }
</style>
