}

.precio-vs-label {
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gray);
  margin-bottom: 12px;
}
.precio-vs-item.bad .precio-vs-label { color: #ff6666; }
.precio-vs-item.good .precio-vs-label { color: var(--lime); }

.precio-vs-amount {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: 28px;
  letter-spacing: -1px;
  margin-bottom: 8px;
}
.precio-vs-amount span {
  font-size: 14px;
  font-weight: 500;
  color: var(--gray);
}
.precio-vs-item.bad .precio-vs-amount {
  color: var(--gray2);
  text-decoration: line-through;
  text-decoration-color: #ff4444;
}
.precio-vs-item.good .precio-vs-amount {
  color: var(--lime);
}

.precio-vs-note {
  font-size: 13px;
  color: var(--gray);
  font-weight: 300;
}

.precio-vs-divider {
  width: 56px;
  height: 56px;
  background: var(--dark4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: 13px;
  color: var(--gray2);
  letter-spacing: 1px;
  flex-shrink: 0;
  z-index: 1;
}

.precios-grid {
  margin-top: 70px;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  background: var(--dark3);
}

.precio-card {
  background: var(--dark);
  padding: 44px 36px;
  position: relative;
  transition: background 0.3s;
}
.precio-card:hover { background: var(--dark3); }

.precio-card.featured {
  background: var(--dark2);
  border-top: 2px solid var(--lime);
}

.precio-tag-featured {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--lime);
  margin-bottom: 24px;
}

.precio-name {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: 26px;
  margin-bottom: 8px;
  letter-spacing: -0.5px;
}

.precio-desc {
  font-size: 13px;
  color: var(--gray);
  margin-bottom: 32px;
  line-height: 1.6;
}

.precio-num {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: 48px;
  letter-spacing: -2px;
  margin-bottom: 4px;
  color: var(--white);
}
.precio-num sup {
  font-size: 22px;
  font-weight: 700;
  letter-spacing: 0;
  vertical-align: super;
}
.precio-card.featured .precio-num { color: var(--lime); }
.precio-slash {
  font-size: 18px;
  font-weight: 500;
