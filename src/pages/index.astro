<style>
:root {
  --lime: #BFFF00;
  --lime-dim: rgba(191,255,0,0.12);
  --lime-dim2: rgba(191,255,0,0.06);
  --lime-glow: rgba(191,255,0,0.15);
  --dark: #0A0A0A;
  --dark2: #101114;
  --dark3: #1C1D21;
  --dark4: #2A2C31;
  --dark5: #343741;
  --lime-dark: #84AC00;
  --white: #F2F2ED;
  --gray: #666;
  --gray2: #999;
  --red-dim: rgba(255,68,68,0.1);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }

body {
  background: var(--dark);
  color: var(--white);
  font-family: 'DM Sans', sans-serif;
  overflow-x: hidden;
  cursor: none;
}

/* ── CUSTOM CURSOR ── */
.cursor {
  position: fixed;
  width: 10px; height: 10px;
  background: var(--lime);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9999;
  transition: transform 0.15s ease;
  mix-blend-mode: difference;
}
.cursor-ring {
  position: fixed;
  width: 36px; height: 36px;
  border: 1px solid rgba(191,255,0,0.4);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9998;
  transition: transform 0.35s ease, width 0.3s, height 0.3s;
}

/* ── NAV ── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 22px 60px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  backdrop-filter: blur(20px);
  background: rgba(8,8,8,0.75);
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.nav-logo {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: 20px;
  letter-spacing: -0.5px;
  color: var(--white);
  text-decoration: none;
}
.nav-logo span { color: var(--lime); }

.nav-links {
  display: flex;
  gap: 40px;
  list-style: none;
}
.nav-links a {
  font-size: 13px;
  color: var(--gray2);
  text-decoration: none;
  letter-spacing: 0.5px;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--white); }

.nav-cta {
  background: var(--lime);
  color: var(--dark);
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 13px;
  padding: 10px 22px;
  text-decoration: none;
  letter-spacing: 0.3px;
  transition: opacity 0.2s, transform 0.2s;
}
.nav-cta:hover { opacity: 0.9; transform: translateY(-1px); }

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  background: none;
  border: none;
  padding: 8px;
  z-index: 200;
}
.hamburger span {
  display: block;
  width: 24px; height: 2px;
  background: var(--white);
  transition: all 0.3s ease;
}
.hamburger.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
.hamburger.active span:nth-child(2) { opacity: 0; }
.hamburger.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

.mobile-menu {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(8,8,8,0.97);
  z-index: 150;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 32px;
  backdrop-filter: blur(20px);
}
.mobile-menu.active { display: flex; }
.mobile-menu a {
  font-family: 'Outfit', sans-serif;
  font-size: 28px;
  font-weight: 700;
  color: var(--white);
  text-decoration: none;
  letter-spacing: -0.5px;
  transition: color 0.2s;
}
.mobile-menu a:hover { color: var(--lime); }
.mobile-menu .nav-cta {
  margin-top: 16px;
  font-size: 16px;
  padding: 14px 32px;
}

/* ── HERO ── */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 140px 60px 80px;
  position: relative;
  overflow: hidden;
}

.hero-noise {
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  opacity: 0.5;
}

.hero-glow {
  position: absolute;
  top: -200px;
  right: -100px;
  width: 700px;
  height: 700px;
  background: radial-gradient(circle, rgba(191,255,0,0.06) 0%, transparent 70%);
  pointer-events: none;
}

.hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--lime);
  margin-bottom: 32px;
  opacity: 0;
  animation: fadeUp 0.8s ease forwards 0.2s;
}
.hero-tag::before {
  content: '';
  width: 20px; height: 1px;
  background: var(--lime);
}

.hero-headline {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: clamp(46px, 6.5vw, 100px);
  line-height: 0.95;
  letter-spacing: -3px;
  max-width: 850px;
  opacity: 0;
  animation: fadeUp 0.9s ease forwards 0.35s;
}
.hero-headline em {
  font-style: normal;
  color: var(--lime);
}

.hero-sub {
  margin-top: 36px;
  font-size: 17px;
  color: var(--gray2);
  max-width: 500px;
  line-height: 1.7;
  font-weight: 300;
  opacity: 0;
  animation: fadeUp 0.9s ease forwards 0.5s;
}

.hero-actions {
  margin-top: 52px;
  display: flex;
  align-items: center;
  gap: 28px;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.9s ease forwards 0.65s;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--lime);
  color: var(--dark);
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 15px;
  padding: 16px 32px;
  text-decoration: none;
  transition: transform 0.2s, box-shadow 0.2s;
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 20px 40px rgba(191,255,0,0.2);
}
.btn-primary svg { width: 16px; height: 16px; }

.btn-ghost {
  font-size: 14px;
  color: var(--gray2);
  text-decoration: none;
  border-bottom: 1px solid var(--gray);
  padding-bottom: 2px;
  transition: color 0.2s, border-color 0.2s;
}
.btn-ghost:hover { color: var(--white); border-color: var(--white); }

/* Hero proof strip */
.hero-proof {
  margin-top: 80px;
  display: flex;
  gap: 48px;
  opacity: 0;
  animation: fadeUp 0.9s ease forwards 0.8s;
}

.proof-item {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 13px;
  color: var(--gray2);
  letter-spacing: 0.3px;
}
.proof-item svg {
  width: 18px; height: 18px;
  color: var(--lime);
  flex-shrink: 0;
}

.hero-scroll {
  position: absolute;
  bottom: 40px;
  right: 60px;
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gray);
  opacity: 0;
  animation: fadeUp 0.9s ease forwards 1s;
}
.scroll-line {
  width: 40px; height: 1px;
  background: var(--gray);
  position: relative;
  overflow: hidden;
}
.scroll-line::after {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 100%; height: 100%;
  background: var(--lime);
  animation: scrollLine 2s ease infinite;
}

/* ── TICKER ── */
.ticker {
  background: var(--lime);
  padding: 14px 0;
  overflow: hidden;
  white-space: nowrap;
}
.ticker-inner {
  display: inline-flex;
  animation: ticker 22s linear infinite;
}
.ticker-item {
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--dark);
  padding: 0 40px;
}
.ticker-dot { color: rgba(0,0,0,0.3); }

/* ── SECTION BASE ── */
section {
  padding: 120px 60px;
}

.section-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--lime);
  margin-bottom: 24px;
}
.section-tag::before {
  content: '';
  width: 16px; height: 1px;
  background: var(--lime);
}

.section-title {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: clamp(36px, 4.5vw, 64px);
  line-height: 1;
  letter-spacing: -2px;
}

/* ── OFERTA GANCHO ── */
.oferta-section {
  background: var(--dark2);
  border-top: 1px solid var(--dark3);
  border-bottom: 1px solid var(--dark3);
  padding: 100px 60px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.oferta-glow {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 800px; height: 500px;
  background: radial-gradient(ellipse, rgba(191,255,0,0.04) 0%, transparent 70%);
  pointer-events: none;
}

.oferta-badge {
  display: inline-block;
  padding: 8px 20px;
  background: var(--lime-dim);
  color: var(--lime);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 32px;
}

.oferta-title {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: clamp(32px, 4vw, 56px);
  line-height: 1.05;
  letter-spacing: -2px;
  max-width: 700px;
  margin: 0 auto 24px;
}
.oferta-title em {
  font-style: normal;
  color: var(--lime);
}

.oferta-sub {
  font-size: 17px;
  color: var(--gray2);
  max-width: 520px;
  margin: 0 auto 16px;
  line-height: 1.7;
  font-weight: 300;
}

.oferta-points {
  display: flex;
  justify-content: center;
  gap: 36px;
  margin: 40px auto 48px;
  max-width: 700px;
  flex-wrap: wrap;
}

.oferta-point {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: var(--white);
}
.oferta-point svg {
  width: 16px; height: 16px;
  color: var(--lime);
  flex-shrink: 0;
}

.oferta-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--lime);
  color: var(--dark);
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 16px;
  padding: 18px 40px;
  text-decoration: none;
  transition: transform 0.2s, box-shadow 0.2s;
}
.oferta-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 24px 48px rgba(191,255,0,0.2);
}

.oferta-note {
  margin-top: 20px;
  font-size: 12px;
  color: var(--gray);
  letter-spacing: 0.5px;
}

/* ── PROBLEMA ── */
.problema {
  background: var(--dark);
}

.problema-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  margin-top: 60px;
}

.problema-copy p {
  font-size: 18px;
  line-height: 1.8;
  color: var(--gray2);
  font-weight: 300;
}
.problema-copy p strong {
  color: var(--white);
  font-weight: 500;
}

.problema-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.problema-item {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  padding: 24px 0;
  border-bottom: 1px solid var(--dark4);
}
.problema-item:first-child { border-top: 1px solid var(--dark4); }

.problema-x {
  width: 28px; height: 28px;
  border: 1px solid #333;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2px;
}
.problema-x svg { width: 12px; height: 12px; stroke: #555; }

.problema-text {
  font-size: 15px;
  color: var(--gray2);
  line-height: 1.6;
}

/* ── ANTES / DESPUÉS ── */
.antes-despues {
  background: var(--dark2);
  border-top: 1px solid var(--dark3);
  position: relative;
}

.ad-intro {
  max-width: 600px;
  margin-bottom: 70px;
}
.ad-intro p {
  font-size: 17px;
  color: var(--gray2);
  line-height: 1.7;
  margin-top: 20px;
  font-weight: 300;
}

.cases-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}

.case-card {
  background: var(--dark);
  border: 1px solid var(--dark3);
  overflow: hidden;
  transition: border-color 0.3s;
}
.case-card:hover { border-color: rgba(191,255,0,0.2); }

.case-header {
  padding: 20px 24px;
  border-bottom: 1px solid var(--dark3);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.case-niche {
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gray);
}
.case-badge {
  font-size: 10px;
  letter-spacing: 1px;
  text-transform: uppercase;
  padding: 4px 10px;
  background: var(--lime-dim);
  color: var(--lime);
}

.case-body {
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.case-before, .case-after { padding: 24px; }
.case-before { border-right: 1px solid var(--dark3); }

.case-label {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gray);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.case-label .dot {
  width: 6px; height: 6px;
  border-radius: 50%;
}
.dot-red { background: #ff4444; }
.dot-green { background: var(--lime); }

.case-text {
  font-size: 13px;
  line-height: 1.7;
  color: var(--gray2);
}
.case-after .case-text { color: var(--white); }

.cases-note {
  margin-top: 36px;
  font-size: 13px;
  color: var(--gray);
  text-align: center;
  font-style: italic;
}

/* ── PROCESO ── */
.proceso { background: var(--dark); }

.proceso-steps {
  margin-top: 70px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}

.step {
  padding: 40px 36px;
  border-right: 1px solid var(--dark3);
  position: relative;
}
.step:last-child { border-right: none; }

.step-num {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: 56px;
  color: var(--dark3);
  line-height: 1;
  margin-bottom: 24px;
  letter-spacing: -2px;
}

.step-title {
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 18px;
  margin-bottom: 12px;
  color: var(--white);
}

.step-desc {
  font-size: 14px;
  color: var(--gray2);
  line-height: 1.7;
  font-weight: 300;
}

.step-accent {
  position: absolute;
  top: 0; left: 0;
  width: 2px; height: 40px;
  background: var(--lime);
}

/* ── PRECIOS ── */
.precios-section {
  background: var(--dark2);
  border-top: 1px solid var(--dark3);
}

.precio-comparison {
  margin-top: 60px;
  margin-bottom: 48px;
}

.precio-vs {
  display: flex;
  align-items: center;
  gap: 0;
  background: var(--dark);
  border: 1px solid var(--dark3);
  overflow: hidden;
}

.precio-vs-item {
  flex: 1;
  padding: 32px 36px;
}

.precio-vs-item.bad {
  background: var(--red-dim);
  border-right: none;
}
.precio-vs-item.good {
