<style>
:root {
  --lime: #BFFF00;
  --lime-soft: #D7FF4D;
  --lime-deep: #84AC00;
  --lime-glow: rgba(191,255,0,0.18);
  --lime-faint: rgba(191,255,0,0.08);
  --ink: #050506;
  --dark: #0A0A0B;
  --dark2: #101012;
  --dark3: #16161A;
  --dark4: #1E1E23;
  --line: rgba(255,255,255,0.06);
  --line2: rgba(255,255,255,0.10);
  --white: #F5F5F0;
  --gray: #6E6E76;
  --gray2: #A0A0A8;
  --red: #FF4D4D;
  --red-dim: rgba(255,77,77,0.12);
  --max: 1280px;
  --r-sm: 12px;
  --r-md: 18px;
  --r-lg: 28px;
  --r-xl: 40px;
  --ease: cubic-bezier(0.22, 1, 0.36, 1);
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

body {
  background: var(--ink);
  color: var(--white);
  font-family: 'DM Sans', system-ui, sans-serif;
  font-size: 16px;
  line-height: 1.6;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  position: relative;
}

/* Global ambient grid background */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: radial-gradient(ellipse at 50% 0%, rgba(0,0,0,0.6) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

main { position: relative; z-index: 1; }

::selection { background: var(--lime); color: var(--ink); }

a { color: inherit; text-decoration: none; }
button { font: inherit; cursor: pointer; background: none; border: none; color: inherit; }
img { max-width: 100%; display: block; }

.container {
  width: 100%;
  max-width: var(--max);
  margin: 0 auto;
  padding: 0 28px;
}

/* ── CURSOR (desktop only) ── */
.cursor, .cursor-ring {
  position: fixed;
  pointer-events: none;
  z-index: 9999;
  display: none;
  will-change: transform;
}
.cursor {
  width: 8px; height: 8px;
  background: var(--lime);
  border-radius: 50%;
  mix-blend-mode: difference;
  transition: transform 0.18s var(--ease);
}
.cursor-ring {
  width: 36px; height: 36px;
  border: 1px solid rgba(191,255,0,0.45);
  border-radius: 50%;
  transition: width 0.3s var(--ease), height 0.3s var(--ease), border-color 0.3s var(--ease);
}
@media (hover: hover) and (pointer: fine) {
  body { cursor: none; }
  .cursor, .cursor-ring { display: block; }
  a, button { cursor: none; }
}

/* ── NAV ── */
.nav-wrap {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 16px 24px;
  display: flex;
  justify-content: center;
  pointer-events: none;
  transition: padding 0.4s var(--ease);
}
.nav-wrap.scrolled { padding-top: 10px; }
nav {
  pointer-events: auto;
  width: 100%;
  max-width: var(--max);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 14px 12px 22px;
  border: 1px solid var(--line);
  background: rgba(10,10,11,0.55);
  backdrop-filter: blur(20px) saturate(140%);
  -webkit-backdrop-filter: blur(20px) saturate(140%);
  border-radius: 100px;
}
.nav-logo {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: 18px;
  letter-spacing: -0.02em;
  display: inline-flex;
  align-items: center;
  gap: 1px;
}
.nav-logo span {
  color: var(--lime);
  text-shadow: 0 0 24px var(--lime-glow);
}
.nav-links {
  display: flex;
  gap: 4px;
  list-style: none;
}
.nav-links a {
  font-size: 13px;
  color: var(--gray2);
  font-weight: 500;
  padding: 8px 14px;
  border-radius: 100px;
  transition: color 0.2s, background 0.2s;
}
.nav-links a:hover { color: var(--white); background: rgba(255,255,255,0.04); }

.nav-cta {
  background: var(--lime);
  color: var(--ink);
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 13px;
  padding: 11px 20px;
  border-radius: 100px;
  letter-spacing: 0.02em;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: transform 0.2s var(--ease), box-shadow 0.3s;
  box-shadow: 0 0 0 0 var(--lime-glow);
}
.nav-cta:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 32px var(--lime-glow);
}

.hamburger {
  display: none;
  width: 40px; height: 40px;
  border-radius: 100px;
  position: relative;
  align-items: center;
  justify-content: center;
}
.hamburger span {
  position: absolute;
  display: block;
  width: 18px; height: 1.5px;
  background: var(--white);
  border-radius: 2px;
  transition: all 0.3s var(--ease);
}
.hamburger span:nth-child(1) { transform: translateY(-5px); }
.hamburger span:nth-child(3) { transform: translateY(5px); }
.hamburger.active span:nth-child(1) { transform: rotate(45deg); }
.hamburger.active span:nth-child(2) { opacity: 0; }
.hamburger.active span:nth-child(3) { transform: rotate(-45deg); }

.mobile-menu {
  position: fixed;
  inset: 0;
  background: rgba(5,5,6,0.96);
  backdrop-filter: blur(28px);
  z-index: 90;
  display: flex;
  flex-direction: column;
  padding: 100px 28px 40px;
  gap: 8px;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-12px);
  transition: opacity 0.3s, transform 0.3s, visibility 0.3s;
}
.mobile-menu.active { opacity: 1; visibility: visible; transform: translateY(0); }
.mobile-menu a {
  font-family: 'Outfit', sans-serif;
  font-size: 32px;
  font-weight: 700;
  letter-spacing: -0.03em;
  padding: 14px 0;
  border-bottom: 1px solid var(--line);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.mobile-menu a::after {
  content: '↗';
  color: var(--gray);
  font-size: 24px;
}
.mobile-menu .nav-cta {
  margin-top: 20px;
  font-size: 16px;
  padding: 16px 28px;
  justify-content: center;
}
.mobile-menu .nav-cta::after { content: none; }

/* ── HERO ── */
.hero {
  position: relative;
  min-height: 100vh;
  padding: 160px 24px 80px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}
.hero-bg::before {
  content: '';
  position: absolute;
  width: 900px; height: 900px;
  left: 50%; top: 30%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(191,255,0,0.18) 0%, rgba(191,255,0,0.06) 40%, transparent 70%);
  filter: blur(20px);
  animation: float 14s ease-in-out infinite;
}
.hero-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 60%, var(--ink) 100%);
}
@keyframes float {
  0%, 100% { transform: translate(-50%, -50%) scale(1); }
  50% { transform: translate(-50%, -45%) scale(1.08); }
}

.hero-eyebrow {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 8px 16px;
  border-radius: 100px;
  background: rgba(191,255,0,0.08);
  border: 1px solid rgba(191,255,0,0.18);
  font-size: 12px;
  font-weight: 500;
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: 0.04em;
  color: var(--lime);
  text-transform: uppercase;
  margin-bottom: 28px;
  backdrop-filter: blur(10px);
}
.hero-eyebrow .dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--lime);
  box-shadow: 0 0 8px var(--lime);
  animation: pulse 1.6s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

.hero-headline {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: clamp(2.6rem, 8vw, 6.5rem);
  line-height: 0.95;
  letter-spacing: -0.04em;
  max-width: 1100px;
  margin: 0 auto 28px;
  position: relative;
}
.hero-headline em {
  font-style: normal;
  position: relative;
  background: linear-gradient(180deg, var(--lime) 0%, var(--lime-soft) 100%);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  display: inline-block;
}
.hero-headline em::after {
  content: '';
  position: absolute;
  left: 0; right: 0; bottom: -4px;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--lime), transparent);
  opacity: 0.6;
}
.hero-strike {
  text-decoration: line-through;
  text-decoration-color: rgba(255,77,77,0.6);
  text-decoration-thickness: 4px;
  color: var(--gray2);
}

.hero-sub {
  font-size: clamp(1.05rem, 1.5vw, 1.25rem);
  color: var(--gray2);
  max-width: 640px;
  margin: 0 auto 40px;
  line-height: 1.55;
}
.hero-sub strong {
  color: var(--white);
  font-weight: 600;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 14px;
  margin-bottom: 28px;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--lime);
  color: var(--ink);
  font-family: 'Outfit', sans-serif;
  font-weight: 700;
  font-size: 15px;
  letter-spacing: 0.01em;
  padding: 16px 26px;
  border-radius: 100px;
  position: relative;
  transition: transform 0.25s var(--ease), box-shadow 0.3s;
  box-shadow: 0 4px 24px rgba(191,255,0,0.18);
}
.btn-primary::before {
  content: '';
  position: absolute;
  inset: -2px;
  border-radius: 100px;
  background: conic-gradient(from 0deg, var(--lime), var(--lime-soft), var(--lime));
  z-index: -1;
  opacity: 0;
  filter: blur(12px);
  transition: opacity 0.3s;
}
.btn-primary:hover { transform: translateY(-2px); }
.btn-primary:hover::before { opacity: 0.7; }
.btn-primary svg { width: 18px; height: 18px; }

.btn-ghost {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 16px 22px;
  border-radius: 100px;
  border: 1px solid var(--line2);
  background: rgba(255,255,255,0.03);
  color: var(--white);
  font-family: 'Outfit', sans-serif;
  font-weight: 500;
  font-size: 14px;
  transition: border-color 0.2s, background 0.2s;
}
.btn-ghost:hover { border-color: var(--lime); background: rgba(191,255,0,0.05); }

.hero-microcopy {
  font-size: 13px;
  color: var(--gray);
  display: inline-flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14px;
}
.hero-microcopy span { display: inline-flex; align-items: center; gap: 6px; }
.hero-microcopy svg { width: 14px; height: 14px; color: var(--lime); }

/* ── TRUST BAR ── */
.trust-bar {
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  padding: 28px 0;
  background: rgba(255,255,255,0.015);
}
.trust-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 28px;
}
.trust-item { text-align: center; }
.trust-num {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  letter-spacing: -0.03em;
  background: linear-gradient(180deg, var(--white) 0%, var(--gray2) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
.trust-item.accent .trust-num {
  background: linear-gradient(180deg, var(--lime) 0%, var(--lime-deep) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
.trust-label {
  font-size: 11px;
  color: var(--gray);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-top: 4px;
  font-family: 'JetBrains Mono', monospace;
}

/* ── MARQUEE ── */
.marquee {
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  background: var(--lime);
  color: var(--ink);
  overflow: hidden;
  padding: 18px 0;
}
.marquee-inner {
  display: flex;
  gap: 32px;
  white-space: nowrap;
  animation: scroll 40s linear infinite;
  width: max-content;
}
.marquee-item {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: 18px;
  letter-spacing: -0.01em;
  text-transform: uppercase;
  display: inline-flex;
  align-items: center;
  gap: 32px;
}
.marquee-item::after {
  content: '✦';
  color: var(--ink);
  opacity: 0.5;
}
@keyframes scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ── SECTION BASE ── */
section.s {
  padding: 120px 0;
  position: relative;
}
.s-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--lime);
  margin-bottom: 18px;
}
.s-tag::before {
  content: '';
  width: 24px; height: 1px;
  background: var(--lime);
}
.s-title {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: clamp(2rem, 5.5vw, 4rem);
  line-height: 1;
  letter-spacing: -0.035em;
  margin-bottom: 24px;
}
.s-title em {
  font-style: normal;
  background: linear-gradient(180deg, var(--lime) 0%, var(--lime-soft) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
.s-lead {
  font-size: clamp(1rem, 1.4vw, 1.15rem);
  color: var(--gray2);
  max-width: 640px;
  line-height: 1.6;
}

/* ── PROBLEMA (BENTO) ── */
.problema-wrap {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 48px;
  align-items: start;
}
.problema-left { padding-top: 12px; }
.problema-left p {
  color: var(--gray2);
  font-size: clamp(1rem, 1.3vw, 1.1rem);
  margin-bottom: 18px;
}
.problema-left strong {
  color: var(--white);
  font-weight: 600;
}

.problema-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
.p-card {
  background: rgba(255,255,255,0.025);
  border: 1px solid var(--line);
  border-radius: var(--r-md);
  padding: 24px 22px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  transition: border-color 0.3s, background 0.3s, transform 0.3s;
  position: relative;
  overflow: hidden;
}
.p-card:hover {
  border-color: rgba(255,77,77,0.3);
  background: rgba(255,77,77,0.04);
  transform: translateY(-2px);
}
.p-icon {
  width: 32px; height: 32px;
  border-radius: 8px;
  background: var(--red-dim);
  border: 1px solid rgba(255,77,77,0.2);
  display: flex; align-items: center; justify-content: center;
  color: var(--red);
}
.p-icon svg { width: 14px; height: 14px; }
.p-card-text {
  font-size: 15px;
  line-height: 1.45;
  color: var(--white);
  font-weight: 500;
}

/* ── BEFORE/AFTER (CHAT-STYLE) ── */
.cases-intro { text-align: center; margin-bottom: 56px; }
.cases-intro .s-tag { justify-content: center; margin-left: auto; margin-right: auto; }
.cases-intro .s-tag::before { display: none; }
.cases-intro .s-title { margin-left: auto; margin-right: auto; }
.cases-intro .s-lead { margin: 0 auto; text-align: center; }

.cases-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}
.case-card {
  background: linear-gradient(180deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 100%);
  border: 1px solid var(--line);
  border-radius: var(--r-lg);
  padding: 28px 24px;
  position: relative;
  transition: border-color 0.3s, transform 0.4s var(--ease);
}
.case-card:hover {
  border-color: var(--line2);
  transform: translateY(-4px);
}
.case-niche {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--gray2);
  padding: 5px 10px;
  border: 1px solid var(--line);
  border-radius: 6px;
  margin-bottom: 24px;
}
.case-msg {
  background: var(--dark3);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 14px 16px;
  margin-bottom: 8px;
  position: relative;
  font-size: 14px;
  line-height: 1.5;
  color: var(--gray2);
}
.case-msg.before {
  border-color: rgba(255,77,77,0.18);
  background: rgba(255,77,77,0.04);
}
.case-msg.after {
  border-color: rgba(191,255,0,0.22);
  background: rgba(191,255,0,0.04);
  color: var(--white);
  font-weight: 500;
}
.case-tag {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 6px;
}
.case-tag.bad { color: var(--red); }
.case-tag.good { color: var(--lime); }
.case-tag .dot { width: 6px; height: 6px; border-radius: 50%; }
.case-tag.bad .dot { background: var(--red); box-shadow: 0 0 6px var(--red); }
.case-tag.good .dot { background: var(--lime); box-shadow: 0 0 6px var(--lime); }
.case-arrow {
  display: flex;
  justify-content: center;
  margin: 6px 0;
  color: var(--gray);
  font-size: 14px;
}

.cases-note {
  text-align: center;
  margin-top: 32px;
  color: var(--gray);
  font-size: 13px;
  font-style: italic;
}

/* ── OFFER ── */
.offer {
  position: relative;
  margin: 0 28px;
  padding: 80px 40px;
  border-radius: var(--r-xl);
  background:
    radial-gradient(circle at 20% 30%, rgba(191,255,0,0.18) 0%, transparent 40%),
    radial-gradient(circle at 80% 70%, rgba(191,255,0,0.10) 0%, transparent 40%),
    linear-gradient(180deg, var(--dark2) 0%, var(--dark) 100%);
  border: 1px solid rgba(191,255,0,0.18);
  text-align: center;
  overflow: hidden;
}
.offer::before {
  content: '';
  position: absolute;
  top: -50%; left: 50%;
  transform: translateX(-50%);
  width: 80%; height: 100%;
  background: radial-gradient(ellipse, rgba(191,255,0,0.10) 0%, transparent 60%);
  filter: blur(40px);
  pointer-events: none;
}
.offer-content { position: relative; max-width: 780px; margin: 0 auto; }
.offer-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 7px 14px;
  border-radius: 100px;
  background: rgba(191,255,0,0.12);
  border: 1px solid rgba(191,255,0,0.3);
  color: var(--lime);
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 24px;
}
.offer h2 {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: clamp(2rem, 5.5vw, 3.6rem);
  line-height: 1.05;
  letter-spacing: -0.035em;
  margin-bottom: 20px;
}
.offer h2 em {
  font-style: italic;
  color: var(--lime);
}
.offer-sub {
  font-size: clamp(1rem, 1.3vw, 1.1rem);
  color: var(--gray2);
  margin-bottom: 32px;
}
.offer-points {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
  margin-bottom: 32px;
}
.offer-point {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  border-radius: 100px;
  border: 1px solid var(--line2);
  background: rgba(255,255,255,0.03);
  font-size: 13px;
  font-weight: 500;
}
.offer-point svg { width: 14px; height: 14px; color: var(--lime); }

/* ── PROCESO ── */
.proceso-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  margin-top: 56px;
  position: relative;
}
.proceso-grid::before {
  content: '';
  position: absolute;
  left: 5%; right: 5%;
  top: 70px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--line2) 10%, var(--line2) 90%, transparent);
  z-index: 0;
}
.step {
  position: relative;
  background: rgba(255,255,255,0.025);
  border: 1px solid var(--line);
  border-radius: var(--r-md);
  padding: 28px 24px;
  transition: border-color 0.3s, background 0.3s, transform 0.3s;
  z-index: 1;
}
.step:hover {
  border-color: var(--lime);
  background: rgba(191,255,0,0.04);
  transform: translateY(-4px);
}
.step-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.12em;
  color: var(--lime);
  margin-bottom: 28px;
}
.step-circle {
  width: 44px; height: 44px;
  border-radius: 50%;
  background: var(--ink);
  border: 1px solid var(--line2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
  color: var(--lime);
  position: relative;
}
.step-circle::after {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  border: 1px solid rgba(191,255,0,0.15);
}
.step-circle svg { width: 18px; height: 18px; }
.step-title {
  font-family: 'Outfit', sans-serif;
  font-size: 18px;
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 8px;
}
.step-desc { font-size: 14px; color: var(--gray2); line-height: 1.5; }

/* ── PRECIOS ── */
.precios-head { text-align: center; max-width: 720px; margin: 0 auto 56px; }
.precios-head .s-tag { justify-content: center; }
.precios-head .s-tag::before { display: none; }

.precio-vs {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 12px;
  align-items: center;
  margin-bottom: 56px;
  background: rgba(255,255,255,0.02);
  border: 1px solid var(--line);
  border-radius: var(--r-lg);
  padding: 24px;
}
.vs-item { padding: 16px 20px; }
.vs-item .vs-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--gray);
  margin-bottom: 8px;
}
.vs-item.bad .vs-label { color: rgba(255,77,77,0.8); }
.vs-item.good .vs-label { color: var(--lime); }
.vs-amount {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: clamp(1.4rem, 2.4vw, 1.9rem);
  letter-spacing: -0.025em;
  margin-bottom: 6px;
}
.vs-amount span { font-size: 0.55em; color: var(--gray); font-weight: 500; }
.vs-item.bad .vs-amount { color: var(--gray2); text-decoration: line-through; text-decoration-color: rgba(255,77,77,0.5); }
.vs-item.good .vs-amount { color: var(--white); }
.vs-note { font-size: 13px; color: var(--gray); }
.vs-divider {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: 14px;
  color: var(--gray);
  letter-spacing: 0.1em;
  padding: 0 12px;
}

.precios-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  align-items: stretch;
}
.precio {
  background: rgba(255,255,255,0.025);
  border: 1px solid var(--line);
  border-radius: var(--r-lg);
  padding: 36px 28px;
  display: flex;
  flex-direction: column;
  position: relative;
  transition: transform 0.3s var(--ease), border-color 0.3s;
}
.precio:hover { border-color: var(--line2); transform: translateY(-3px); }
.precio.featured {
  background: linear-gradient(180deg, rgba(191,255,0,0.05) 0%, rgba(255,255,255,0.02) 100%);
  border-color: rgba(191,255,0,0.3);
  position: relative;
}
.precio.featured::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: var(--r-lg);
  padding: 1px;
  background: linear-gradient(180deg, rgba(191,255,0,0.5), rgba(191,255,0,0.05));
  -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
  mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}
.precio-tag {
  position: absolute;
  top: -10px; left: 50%;
  transform: translateX(-50%);
  background: var(--lime);
  color: var(--ink);
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  padding: 5px 12px;
  border-radius: 100px;
  text-transform: uppercase;
  box-shadow: 0 4px 16px var(--lime-glow);
}
.precio-name {
  font-family: 'Outfit', sans-serif;
  font-size: 14px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: var(--gray2);
  margin-bottom: 6px;
}
.precio.featured .precio-name { color: var(--lime); }
.precio-desc { font-size: 14px; color: var(--gray); margin-bottom: 28px; line-height: 1.5; }
.precio-num {
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: clamp(2.2rem, 4vw, 3rem);
  letter-spacing: -0.035em;
  line-height: 1;
  margin-bottom: 6px;
  display: flex;
  align-items: flex-start;
}
.precio-num sup {
  font-size: 0.5em;
  font-weight: 600;
  margin-right: 4px;
  margin-top: 0.4em;
  color: var(--gray2);
}
.precio-num .slash {
  font-size: 0.32em;
  font-weight: 500;
  color: var(--gray);
  margin-top: 1.4em;
  margin-left: 4px;
}
.precio-period {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--gray);
  letter-spacing: 0.08em;
  margin-bottom: 28px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--line);
}
.precio-feats {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 32px;
  flex-grow: 1;
}
.precio-feats li {
  font-size: 14px;
  color: var(--white);
  display: flex;
  align-items: flex-start;
  gap: 10px;
  line-height: 1.5;
}
.precio-feats li::before {
  content: '';
  flex-shrink: 0;
  width: 18px; height: 18px;
  border-radius: 50%;
  background: var(--lime-faint);
